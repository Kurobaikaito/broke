APP_NAME=A-Share Stock Selector
APP_DEMO_MODE=true
AUTO_CREATE_TABLES=false
DATABASE_URL=mysql+pymysql://root:change_me@localhost:3306/stock_selector?charset=utf8mb4
TUSHARE_TOKEN=replace_with_your_tushare_pro_token

# 0 keeps source data permanently. A finite horizon below 650 days is rejected
# because it cannot support the default factor warm-up and purged model window.
DATA_RAW_RETENTION_DAYS=0
# Only recent diagnostic factor cross-sections are materialized; training uses wide in-memory factors.
DATA_FACTOR_RETENTION_DAYS=90
# Serving predictions are reproducible; the current serving snapshot is always protected.
DATA_PREDICTION_RETENTION_DAYS=365
DATA_MAINTENANCE_AUDIT_RETENTION_DAYS=180
DATA_MAINTENANCE_BATCH_SIZE=5000
